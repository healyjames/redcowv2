---
import { Image } from "astro:assets";
import Separator from "../components/Separator.astro";
import Logo from "@brand/logo/black.svg"
import { contact, socialLinks, footerNavigation, businessInfo } from "@brand/content";

const currentYear = new Date().getFullYear();
---
<style>
  .site-footer {
    margin-top: 2rem;
  }

  .footer-top {
    padding: 2rem 1rem;
    max-width: 64rem;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .footer-links p {
    margin: 0.5rem 0;
  }

  .footer-links p a {
    display: block;
    width: 100%;
    padding: 0.25rem;
    border-radius: 0.25rem;
  }

  .footer-links p a:hover {
    color: var(--primary);
    background-color: var(--background-dark);
  }

  .footer-heading {
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .footer-logo-wrapper {
    display: none;
  }

  .footer-logo {
    width: 200px;
    height: auto;
    margin: 0 auto 1rem auto;
  }

  .footer-social {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .icon {
    width: 1.5rem;
    height: 1.5rem;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--secondary);
    transition: color 0.2s ease;
    border-radius: 100%;
    border: 2px solid var(--secondary);
    padding: 0.25rem;
  }
  .social-icon:hover {
    color: var(--secondary-darker);
    border: 2px solid var(--secondary-darker);
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem 2rem 1rem;
    gap: 0.5rem;
    text-align: center;
    p {
      margin: 0;
    }
    .address {
      font-size: 0.9rem;
    }
    .phone {
      font-weight: bold;
      font-size: 1.1rem;
      letter-spacing: 0.1rem;
      font-family: 'SecondaryFont';
    }
  }

  .footer-legal {
    padding: 0.5rem 1rem;
    background-color: var(--secondary);
    text-align: center;
    color: #ffffff;
    margin: 0;
    font-size: 0.875rem;
    a:hover {
      border-bottom: 1px solid #ffffff;
    }
  }

  @media (min-width: 768px) {
    .footer-info {
      text-align: left;
      flex-direction: row;
      justify-content: space-between;
    }

    .footer-legal {
      display: flex;
      flex-direction: row;
      justify-content: space-between;
    }

    .footer-logo-wrapper {
      display: block;
      text-align: center;
    }

    .footer-top {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-links {
      gap: 1rem;
    }
  }
</style>
<footer class="site-footer">
  <Separator color="--secondary-lighter" />
  <section class="footer-top">
    <div class="footer-links">
      <div>
        <h4 class="footer-heading">About</h4>
        {footerNavigation.about.map(link => (
          <p><a href={link.href}>{link.text}</a></p>
        ))}
      </div>
      <div>
        <h4 class="footer-heading">Menu</h4>
        {footerNavigation.menu.map(link => (
          <p><a href={link.href}>{link.text}</a></p>
        ))}
      </div>
      <div>
        <h4 class="footer-heading">Other</h4>
        {footerNavigation.other.map(link => (
          <p><a href={link.href}>{link.text}</a></p>
        ))}
      </div>
    </div>
    
    <div class="footer-logo-wrapper">
      <div>
        <Image
          src={Logo}
          alt="Red Cow Logo"
          loading="lazy"
          decoding="async"
          class="footer-logo"
        />
      </div>
      <div class="footer-social">
        {socialLinks.map(social => (
          <a href={social.url} aria-label={social.ariaLabel} class="social-icon">
            {social.name === "Facebook" && (
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            )}
            {social.name === "Instagram" && (
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
              </svg>
            )}
            {social.name === "TikTok" && (
              <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="18" r="4"/>
                <path d="M12 18V2l7 4"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <Separator color="--secondary-lighter" />
  
  <section class="footer-info">
    <p class="address">{contact.address.street}, {contact.address.town}, {contact.address.postcode}</p>
    <p class="phone">{contact.phoneFormatted}</p>
  </section>

  <section class="footer-legal">
    <p>© {businessInfo.name} {currentYear} - All Rights Reserved</p>
    <p>Site by <a href="https://www.jameshealy.co.uk" target="_blank">James Healy</a></p>
  </section>
</footer>
